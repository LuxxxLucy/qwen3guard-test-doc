.DS_Store

# Build outputs, regenerated by ./build.sh and by the Pages workflow.
# Derived from main.typ + figures/src/ + the vendored template, so never tracked.
/main.pdf
/index.html
/figures/output/

# vendor/dual-typst is a real re-vendored copy (src + fonts), tracked so the
# repo builds standalone in CI. If the local working copy is instead a symlink
# to the sibling canonical checkout, re-vendor before publishing.

.vscode/
